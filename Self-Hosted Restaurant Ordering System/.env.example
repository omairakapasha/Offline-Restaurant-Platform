# ──────────────────────────────────────────────────────────────
#  Self-Hosted Restaurant Ordering System — Environment Config
# ──────────────────────────────────────────────────────────────
#  Copy this file:  cp .env.example .env
#  Then edit the values below. Lines marked [REQUIRED] must be set.
#  Lines marked [FIRST RUN] are only used when the database is empty.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# Docker users: leave as-is; docker-compose overrides this.
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/restaurant

# ── Session ───────────────────────────────────────────────────
# [REQUIRED] Must be at least 32 random characters. The server
# refuses to start without it.
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-use-a-random-string-of-at-least-32-characters

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Public URL / QR Codes ────────────────────────────────────
# [IMPORTANT] The URL your customers will use to reach the system.
# QR codes on each table are encoded with this URL.
#
# Set this to the address phones on your restaurant WiFi can reach:
#   - Local network:  http://192.168.1.100:5000
#   - With a domain:  https://order.myrestaurant.com
#
# If left as localhost, QR codes will only work on the server itself.
CORS_ORIGIN=http://localhost:5000

# ── Branding ──────────────────────────────────────────────────
# Shown on the customer page header, receipts, and page titles.
BRAND_NAME=Your Restaurant Name
BRAND_TAGLINE=Scan · Order · Enjoy

# ── Currency ──────────────────────────────────────────────────
# CURRENCY_SYMBOL is displayed with prices (e.g. "QAR", "USD", "€")
# CURRENCY_CODE is used in API responses and data storage
CURRENCY_SYMBOL=QAR
CURRENCY_CODE=QAR

# ── Default Staff Credentials ─────────────────────────────────
# [FIRST RUN] These create the initial staff accounts when the
# database is empty. Change the passwords to something strong.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_KITCHEN_USERNAME=kitchen
DEFAULT_KITCHEN_PASSWORD=kitchen123
DEFAULT_WAITER_USERNAME=waiter
DEFAULT_WAITER_PASSWORD=waiter123

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── AI Menu Assistant (optional) ──────────────────────────────
# The customer page has a chat bubble that answers menu questions.
#
# GEMINI_API_KEY:
#   - set    → Gemini is used; falls back to local model on outage
#   - unset  → local model handles every request (fully offline)
GEMINI_API_KEY=

# Local fallback model (Ollama). Install Ollama, then:
#   ollama pull llama3.2:3b
# OLLAMA_BASE_URL:
#   Local dev: http://localhost:11434
#   Docker:    http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2:3b

# ── Internal Service Auth ─────────────────────────────────────
# Shared secret between Express and the Python AI service.
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=

# URL of the Python AI microservice
#   Local dev: http://localhost:8001
#   Docker:    http://ai-chat:8001
AI_SERVICE_URL=http://localhost:8001

# ── Web Push Notifications (optional) ─────────────────────────
# Enables "Notify me when ready" on the order tracking page.
# Requires HTTPS. Generate keys once:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourrestaurant.com
