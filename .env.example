# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/restaurant

# Session — must be at least 32 random characters
SESSION_SECRET=change-me-use-a-random-string-of-at-least-32-characters

# Server
NODE_ENV=production
PORT=5000
CORS_ORIGIN=http://localhost:5000

# Branding — shown on the customer header, receipt, and page titles.
# Leave unset to use the built-in defaults.
BRAND_NAME=The Corner Table
BRAND_TAGLINE=Scan · Order · Enjoy

# Default staff credentials (set before first run — change on first login)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_KITCHEN_USERNAME=kitchen
DEFAULT_KITCHEN_PASSWORD=
DEFAULT_WAITER_USERNAME=waiter
DEFAULT_WAITER_PASSWORD=

# Logging
LOG_LEVEL=info

# AI Chat — the customer menu assistant uses Gemini as the primary backend and
# a local model (via Ollama) as an offline fallback.
#
# GEMINI_API_KEY is now OPTIONAL:
#   - set      → Gemini is used whenever reachable, local model on outage/quota
#   - unset    → the local model handles every request (fully offline)
GEMINI_API_KEY=

# Local fallback model (Ollama). Install Ollama, then: ollama pull llama3.2:3b
# OLLAMA_BASE_URL — where the Ollama server listens.
#   Local dev: http://localhost:11434   Docker: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2:3b

# Internal shared secret — Express proxy → Python AI service
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# URL of the Python AI microservice
# Local dev: http://localhost:8001   Docker: http://ai-chat:8001
AI_SERVICE_URL=http://localhost:8001

# Web Push (VAPID) — required for order-ready browser notifications
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourrestaurant.com
