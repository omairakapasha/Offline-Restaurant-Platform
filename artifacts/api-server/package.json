{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "description": "Express 5 API server for Restaurant Management System",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node --import tsx/esm ./src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node --import tsx/esm ./src/index.ts",
    "test": "vitest --run"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.30.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "pg": "^8.11.0",
    "pino": "^8.17.2",
    "qrcode": "^1.5.4",
    "tsx": "^4.7.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.16.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.56.0",
    "fast-check": "^3.22.0",
    "pino-pretty": "^10.3.1",
    "supertest": "^7.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
